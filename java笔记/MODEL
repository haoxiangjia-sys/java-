import com.google.common.collect.ImmutableSet;

import uk.ac.bris.cs.scotlandyard.model.Board.GameState;
import uk.ac.bris.cs.scotlandyard.model.Move.DoubleMove;
import uk.ac.bris.cs.scotlandyard.model.Move.SingleMove;
import uk.ac.bris.cs.scotlandyard.model.Piece.Detective;
import uk.ac.bris.cs.scotlandyard.model.Piece.MrX;
import uk.ac.bris.cs.scotlandyard.model.ScotlandYard.Factory;
import uk.ac.bris.cs.scotlandyard.model.ScotlandYard.Transport;

public final class MyGameStateFactory implements Factory<GameState> {  // mygamestatefactory is the implement , gamestate is interface

	@Nonnull  //mean this way not return the null
	@Override  // the methed need implements 
	public GameState build(GameSetup setup, Player mrX, ImmutableList<Player> detectives) {
		return new MyGameState(setup, ImmutableSet.of(MrX.MRX), ImmutableList.of(), mrX, detectives);
	}
//Build() creates the initial game state.
//GameSetup contains game rules and map.
//Immutable means cannot be changed after creation.
//MrX.MRX： It’s an enum value (enumeration) inside the Piece.MrX class.  //We use it to identify that it’s Mr.X’s turn to move first.

//public is an access modifier.
//GameState is the return type.
//build is the method name.

//GameSetup is a type, setup is the parameter name.
//Player is a type, mrX is the parameter name.
//ImmutableList<Player> is a type, detectives is the parameter name.

//This method creates and returns a new MyGameState.



	private final class MyGameState implements GameState {
		private GameSetup setup; //GameSetup → type (holds game rules, map, rounds). //setup → variable name.
		private ImmutableSet<Piece> remaining; //type (unchangeable set of players). //remaining → stores which players still need to move. 
        // //<Piece> Generics means: This is a Set that holds only Piece objects. It makes code type-safe and avoids casting errors.
		private ImmutableList<LogEntry> log; //ImmutableList<LogEntry> → type. //log → stores MrX’s travel history.
		private Player mrX;
		private List<Player> detectives;
		private ImmutableSet<Move> moves; //moves → stores all valid, available moves.
		private ImmutableSet<Piece> winner;
//private → access modifier (encapsulation, not accessible from outside).
//final → means this class cannot be inherited/extended
//class → it’s a Java class.
//MyGameState → the name of the class.
//implements GameState → this class provides an implementation for the GameState interface





		private MyGameState(
				final GameSetup setup,
				final ImmutableSet<Piece> remaining,
				final ImmutableList<LogEntry> log,
				final Player mrX,
				final List<Player> detectives) {
//This is a CONSTRUCTOR //It creates a new MyGameState object.

			if (!mrX.isMrX())
				throw new IllegalArgumentException("No mrX!");
			if (detectives.isEmpty())
				throw new IllegalArgumentException("Detectives is empty!");
			if (setup.moves.isEmpty())
				throw new IllegalArgumentException("Moves is empty!");
			if (setup.graph.edges().isEmpty())
				throw new IllegalArgumentException("Graph is empty!");

			Set<Integer> locations = new HashSet<>();
			Set<Piece> pieces = new HashSet<>();
//Set<Integer> = A Set of Integer values
//HashSet<>() = An implementation of the Set interface
//Set = A collection that does NOT allow duplicates
//Purpose: To check that no two detectives are on the same spot.

			for (Player d : detectives) { //For-Each Loop//It loops through every element in the detectives list.
				if (!pieces.add(d.piece()))
					throw new IllegalArgumentException("Duplicated detectives");
				if (!locations.add(d.location()))
					throw new IllegalArgumentException("Detectives sharing same location");
			}

			for (Player d : detectives) {
				if (d.has(ScotlandYard.Ticket.SECRET))
					throw new IllegalArgumentException("Detective should not have secret tickets");
				if (d.has(ScotlandYard.Ticket.DOUBLE))
					throw new IllegalArgumentException("Detective should not have double tickets");
			}
//If invalid → throw Exception  //If the game state is wrong → stop and show error.

			this.setup = setup;
			this.remaining = remaining;
			this.log = log;
			this.mrX = mrX;
			this.detectives = detectives;
			this.winner = getWinner();
			this.moves = getAvailableMoves();
		}
//Finally, it assigns all values to the fields,

		@Nonnull
		@Override
		public GameSetup getSetup() {
			return setup;
		}
//GameSetup: Return type
//getSetup(): A getter method
//return setup: Returns the game’s configuration (map, rules, rounds)

		@Nonnull
		@Override
		public ImmutableSet<Piece> getPlayers() {
			List<Piece> all = new ArrayList<>();  //Creates a new list
			all.add(mrX.piece());   //Adds MrX’s piece
			for (Player d : detectives)   //Uses a for-each loop to add all detective pieces
				all.add(d.piece());
			return ImmutableSet.copyOf(all); //Converts to immutable set and returns it
		}

		@Nonnull
		@Override
		public ImmutableSet<Piece> getWinner() {
			ImmutableSet<Piece> detectivePieces = ImmutableSet.copyOf(
					detectives.stream().map(Player::piece).collect(Collectors.toSet()));

			// Detectives win

			// 1. A detective has landed on the same station as MrX
			for (Player d : detectives) {
				if (d.location() == mrX.location())
					return detectivePieces; // detective caught mrx
			}

			// 2. MrX has no stations to travel to (cornered) and it is his turn
			if (remaining.contains(MrX.MRX) && makeSingleMoves(setup, detectives, mrX, mrX.location()).isEmpty() //It is MrX’s turn to move right now. //He cannot move anywhere.
					&& log.size() < setup.moves.size()) {// the game not over //
				return detectivePieces;
			}

			// MrX wins

			// 3. The travel log is completely filled and it is back to MrX's turn
			// (detectives have already taken their final moves without catching him)
			if (log.size() >= setup.moves.size() && remaining.contains(MrX.MRX)) { //The game rounds are finished  //He survived all rounds
				return ImmutableSet.of(MrX.MRX);
			}

			// 4. Every detective is stuck (no tickets / no reachable nodes) – evaluated
			// at the start of MrX's turn so we know all detectives have been checked
			boolean allDetectivesStuck = detectives.stream()
					.allMatch(d -> makeSingleMoves(setup, detectives, d, d.location()).isEmpty()); //only if ALL detectives have no moves. returns true

			if (allDetectivesStuck && remaining.contains(MrX.MRX)) { //All detectives can’t move. //It is MrX’s turn now.
				return ImmutableSet.of(MrX.MRX);
			}
			return ImmutableSet.of(); //If no winner, return empty set.
		}

		@Nonnull
		@Override
		public Optional<Integer> getDetectiveLocation(Detective detective) {
			for (Player d : detectives) {  //Loop through all detectives
				if (d.piece() == detective)
					return Optional.of(d.location());
			}
			return Optional.empty();
		}
//Optional<Integer>: Return type — returns a location or nothing (if not found) //Optional is used to avoid null pointers.

		@Nonnull
		@Override
		public Optional<TicketBoard> getPlayerTickets(Piece piece) { //（Piece = the TYPE (class / enum)，piece = the PARAMETER NAME）
			if (piece == mrX.piece())
				return Optional.of(t -> mrX.tickets().get(t));

			for (Player d : detectives) {
				if (d.piece() == piece)
					return Optional.of(t -> d.tickets().get(t));
			}
			return Optional.empty();
		}
//First, check if the piece is MrX，If yes → return MrX’s tickets
//If not MrX, loop through detectives，Find the matching detective
//If no player found → return Optional.empty()

		@Nonnull
		@Override
		public ImmutableList<LogEntry> getMrXTravelLog() {
			return log;
		}

		private static ImmutableSet<SingleMove> makeSingleMoves( //private static: Only for internal use, belongs to the class
				GameSetup setup, List<Player> detectives, Player player, int source) {  //source: current location of the player

			Set<Integer> occupiedByDetective = new HashSet<>();
			for (Player d : detectives) {
				occupiedByDetective.add(d.location());
			}//Saves all locations where detectives are standing

			Set<SingleMove> singleMoves = new HashSet<>();

			for (int destination : setup.graph.adjacentNodes(source)) {  //Loop through all nearby stations
				if (occupiedByDetective.contains(destination))  //If a detective is there → skip this destination
					continue;

				for (Transport t : setup.graph.edgeValueOrDefault(source, destination, ImmutableSet.of())) {
					if (player.has(t.requiredTicket())) {
						singleMoves.add(new SingleMove(player.piece(), source, t.requiredTicket(), destination));
					}
				}//If player has the correct ticket → add the move

				if (player.has(ScotlandYard.Ticket.SECRET)) {
					singleMoves.add(new SingleMove(player.piece(), source, ScotlandYard.Ticket.SECRET, destination));
				}//If player has a secret ticket → can move to any adjacent node
			}
			return ImmutableSet.copyOf(singleMoves);
		}

		private static ImmutableSet<DoubleMove> makeDoubleMoves(
				GameSetup setup, List<Player> detectives, Player player, int source,
				ImmutableList<LogEntry> log) {

			Set<DoubleMove> doubleMoves = new HashSet<>();

			// Can only do a double move if:
			// 1. Player has a double ticket
			// 2. There are at least 2 moves remaining in the setup
			if (!player.has(ScotlandYard.Ticket.DOUBLE) || setup.moves.size() - log.size() < 2) //There must be at least 2 moves left in the game
				return ImmutableSet.of();

			Set<SingleMove> firstMoves = makeSingleMoves(setup, detectives, player, source);

			for (SingleMove first : firstMoves) {
				// Temporarily "spend" the first move ticket to check if second move is valid
				Player playerAfterFirst = player.use(ScotlandYard.Ticket.DOUBLE).use(first.ticket);

				Set<SingleMove> secondMoves = makeSingleMoves(setup, detectives, playerAfterFirst, first.destination);

				for (SingleMove second : secondMoves) {
					doubleMoves.add(new Move.DoubleMove(  //Combine the first move + second move into one DoubleMove
							player.piece(),
							source, first.ticket, first.destination,
							second.ticket, second.destination));
				}
			}
			return ImmutableSet.copyOf(doubleMoves);
		}

		@Nonnull
		@Override
		public ImmutableSet<Move> getAvailableMoves() {
			if (!winner.isEmpty())
				return ImmutableSet.of();

			Set<Move> allMoves = new HashSet<>();

			if (remaining.contains(mrX.piece())) {  
				allMoves.addAll(makeSingleMoves(setup, detectives, mrX, mrX.location()));
				allMoves.addAll(makeDoubleMoves(setup, detectives, mrX, mrX.location(), log)); //If it’s MrX’s turn → add all single moves + all double moves.
			} else {
				for (Player detective : detectives) {
					if (remaining.contains(detective.piece())) {
						allMoves.addAll(makeSingleMoves(setup, detectives, detective, detective.location())); //Loop through detectives.If it’s a detective’s turn → add their single moves.
					}
				}
			}
			return ImmutableSet.copyOf(allMoves);
		}

		@Nonnull
		@Override
		public GameState advance(Move move) { //makes a move and creates a NEW game state
			if (!moves.contains(move))
				throw new IllegalArgumentException("Illegal move: " + move);

			return move.accept(new Move.Visitor<GameState>() { //Visitor handle different types of moves
//The accept method dispatches the logic to the correct handler.
				@Override
				public GameState visit(Move.SingleMove m) {   //executes specifically when the move is a SingleMove
					if (m.commencedBy().isMrX()) {  ////If the move is made by MrX
						Player newMrX = mrX.use(m.ticket).at(m.destination);  //Create new MrX at new location, using the ticket

						LogEntry entry = setup.moves.get(log.size())  //This creates a log entry to record his move, either revealing or hiding his position.
								? LogEntry.reveal(m.ticket, m.destination)
								: LogEntry.hidden(m.ticket);

						ImmutableList<LogEntry> newLog = ImmutableList.<LogEntry>builder()  //A new, immutable log list is created by adding the new entry to the old history.
								.addAll(log).add(entry).build();

						ImmutableSet<Piece> newRemaining = ImmutableSet.copyOf(
								detectives.stream().map(Player::piece).collect(Collectors.toList()));  //After Mr. X moves, the next turn belongs to all the detectives.

						return new MyGameState(setup, newRemaining, newLog, newMrX, detectives);
					} else {
						List<Player> newDetectives = detectives.stream()
								.map(d -> d.piece() == m.commencedBy() ? d.use(m.ticket).at(m.destination) : d)
								.collect(Collectors.toList());

						Player newMrX = mrX.give(m.ticket);  //After a detective uses a ticket, it is given back to Mr. X.

						Set<Piece> remainingPieces = remaining.stream()
								.filter(p -> p != m.commencedBy())
								.collect(Collectors.toCollection(HashSet::new));  //The detective who just moved is removed from the remaining list.

						remainingPieces.removeIf(p -> newDetectives.stream()  //This method removes elements from the set if the condition is true.
								.filter(d -> d.piece() == p)       //We find the detective that matches the piece p
								.findFirst()
								.map(d -> makeSingleMoves(setup, newDetectives, d, d.location()).isEmpty())  //if ture → The detective has NO moves → he is stuck.
								.orElse(false)); //If the detective is not found → do not remove.

						ImmutableSet<Piece> newRemaining = remainingPieces.isEmpty()  //We take the current remaining list  
								? ImmutableSet.of(MrX.MRX)
								: ImmutableSet.copyOf(remainingPieces);
//If the remaining list is empty, it means all detectives have moved.//The turn automatically switches back to Mr. X.
						return new MyGameState(setup, newRemaining, log, newMrX, newDetectives);
					}
				}

				@Override
				public GameState visit(Move.DoubleMove m) {  
					Player newMrX = mrX
							.use(ScotlandYard.Ticket.DOUBLE)
							.use(m.ticket1)
							.use(m.ticket2)
							.at(m.destination2);

					LogEntry entry1 = setup.moves.get(log.size())
							? LogEntry.reveal(m.ticket1, m.destination1)
							: LogEntry.hidden(m.ticket1);

					LogEntry entry2 = setup.moves.get(log.size() + 1)
							? LogEntry.reveal(m.ticket2, m.destination2)
							: LogEntry.hidden(m.ticket2);  //Each entry checks if it needs to reveal position or hide

					ImmutableList<LogEntry> newLog = ImmutableList.<LogEntry>builder()
							.addAll(log).add(entry1).add(entry2).build();  //Adds both log entries to the game history

					ImmutableSet<Piece> newRemaining = ImmutableSet.copyOf(
							detectives.stream().map(Player::piece).collect(Collectors.toList()));
//detectives.stream()We take all the detectives in the game.
//.map(Player::piece)We convert each detective Player into their Piece (like Detective1, Detective2).
//.collect(Collectors.toList())We collect all those detective pieces into a list.
//ImmutableSet.copyOf(...)We make an immutable set of all detective pieces.
//newRemainingThis variable means:These are the players who still need to take their turn.

					return new MyGameState(setup, newRemaining, newLog, newMrX, detectives);
				}
			});
		}
	}
}